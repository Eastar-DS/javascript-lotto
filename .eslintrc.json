{
  "rules": {
    "max-depth": ["error", 1],
    "max-params": ["error", 2],
    "no-var": "error",
    "prefer-const": "error"
  },
  "env": {
    "es6": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"]
}
